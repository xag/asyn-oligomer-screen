# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.python-version

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Vina binary (download once from upstream release page)
bin/vina*

# PDB cache (auto-populated from RCSB on first run)
data/anchors/

# Per-pair Stage 3 artifacts — regenerable, large, many
results/stage3/*.pdb
results/stage3/*.pdbqt
results/stage3/*.log
# Keep the JSON reports if a contributor wants to inspect them; they are small.
# To exclude reports too, uncomment:
# results/stage3/*.json

# Run logs
results/_logs/

# Dwell-time channel: replica MD trajectories are large + regenerable.
# pilot_summary.{json,csv} are small; keep them so the pilot result is
# inspectable without re-running the MD.
results/dwell/**/*.pdb
results/dwell/**/*.log
results/dwell/_scratch/

# Distributable chunk experiments: per-experiment store is runtime state —
# content-addressed artifacts (systems, States, frame PDBs), scratch, manifests,
# logs — all large + regenerable from `run_chunks.py create`.
experiments/

# Per-topology oligomer build/relax logs (the relaxed PDBs are kept)
results/oligomers/_*.log
results/oligomers/*.log
# The unrelaxed intermediates can be regenerated from the build script
results/oligomers/fusco_*_3mer_core*.pdb
!results/oligomers/*_relaxed.pdb

# Conda env / lockfiles
*.lock
environment.yml.local

# Misc transient
*.tmp
*.bak

# Outreach
outreach/

# ops/: the generic SSH cluster tooling is tracked; only the machine-specific
# config and the survey reports (which name the hosts) stay out of git.
ops/local.ps1
ops/*.txt